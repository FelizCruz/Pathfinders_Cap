# Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# GitHub Models / Azure OpenAI Configuration (Required)
GITHUB_TOKEN=your-github-token-here
OPENAI_ENDPOINT=https://models.inference.ai.azure.com
OPENAI_MODEL=gpt-5-chat
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# News API Configuration (Required)
NEWS_API_KEY=your-news-api-key-here
NEWS_API_URL=https://newsapi.org/v2

# Kalshi API Configuration (Optional - demo uses sample data if not provided)
KALSHI_API_URL=https://api.elections.kalshi.com/v1
KALSHI_API_KEY=your-kalshi-api-key-here

# Azure Text Analytics Configuration (Optional)
AZURE_TEXT_ANALYTICS_ENDPOINT=https://your-text-analytics-resource.cognitiveservices.azure.com/
AZURE_TEXT_ANALYTICS_KEY=your-text-analytics-key-here
AZURE_TEXT_ANALYTICS_KEY_2=your-secondary-text-analytics-key-here